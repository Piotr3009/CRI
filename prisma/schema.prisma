// CRI — Construction Risk Intelligence
// Prisma schema. See README.md for setup instructions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  CONTRACTOR
  ADMIN
}

enum VerifiedStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum EntityType {
  RESIDENTIAL_CLIENT
  COMMERCIAL_CLIENT
  DEVELOPER
  MAIN_CONTRACTOR
  PROJECT_MANAGER
  QUANTITY_SURVEYOR
  ARCHITECT_PM
  MANAGEMENT_COMPANY
  HOUSING_ASSOCIATION
}

enum ProjectType {
  REFURBISHMENT
  EXTENSION
  JOINERY
  WINDOWS_AND_DOORS
  ELECTRICAL
  PLUMBING
  ROOFING
  DECORATION
  NEW_BUILD
  OTHER
}

enum ProjectStatus {
  COMPLETED
  ONGOING
  CANCELLED
  DISPUTED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum AverageResponseTime {
  UNDER_24H
  ONE_TO_THREE_DAYS
  THREE_TO_SEVEN_DAYS
  ONE_TO_TWO_WEEKS
  MORE_THAN_TWO_WEEKS
}

enum EvidenceStatus {
  UNVERIFIED
  BASIC_EVIDENCE
  VERIFIED_EVIDENCE
  LEGAL_EVIDENCE
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  DISPUTED
}

enum Visibility {
  PUBLIC
  VERIFIED_CONTRACTORS_ONLY
  ADMIN_ONLY
}

enum EvidenceReviewStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum RightToReplyStatus {
  PENDING
  PUBLISHED
  REJECTED
}

// Tri-state answers used by some report questions. Stored as enums for type
// safety. (Not in the original enum list but kept minimal and report-scoped.)
enum YesNoUnsure {
  YES
  NO
  NOT_SURE
}

enum PaymentLateStatus {
  YES
  NO
  PARTIALLY
}

// Behaviour answers for the Private Client survey (Level 1 raw fact capture).
// Aggregated into a 1–10 score only in the final report (Level 2).
enum BehaviourAnswer {
  YES
  SOMETIMES
  NO
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  name           String?
  companyName    String?
  phone          String?
  role           UserRole       @default(CONTRACTOR)
  verifiedStatus VerifiedStatus @default(UNVERIFIED)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  reports RiskReport[]
}

model RiskReport {
  id String @id @default(cuid())

  // --- Reporter details (PRIVATE — never exposed on public pages) ---
  reporter            User?   @relation(fields: [reporterId], references: [id], onDelete: SetNull)
  reporterId          String?
  reporterCompanyName String
  reporterContactName String
  reporterEmail       String
  reporterPhone       String?
  reporterTradeType   String

  // --- Entity being reported ---
  entityType          EntityType
  entityName          String? // optional for residential clients
  clientInitials      String? // residential only, e.g. "C.A."
  companiesHouseNumber String? // UK CRN of the reported company (not residential); optional until Companies House autocomplete lands
  isResidential       Boolean    @default(false)
  projectAddressLine1 String? // PRIVATE — never exposed publicly
  projectCity         String?
  projectPostcode     String? // PRIVATE for residential — only a prefix is public
  publicArea          String // e.g. "SW19", "NW London", "Manchester"

  // --- Project details ---
  projectType        ProjectType
  contractValueRange String? // e.g. "UNDER_5K", "100K_PLUS" (legacy, unused)
  contractValueGbp   Int?    // przybliżona wartość kontraktu £
  contractLength     String? // długość kontraktu: UNDER_1_MONTH ... OVER_2_YEARS
  startDate          DateTime?
  finishDate         DateTime? // actual project end (optional; blank while ongoing)
  projectStatus      ProjectStatus @default(COMPLETED)

  // --- Risk scoring ---
  paymentScore                       Float // 0–10
  communicationScore                 Float // 0–10
  variationRisk                      RiskLevel
  disputeRisk                        RiskLevel
  averageResponseTime                AverageResponseTime?
  extrasRequestedWithoutApprovedCost YesNoUnsure?
  paymentLate                        PaymentLateStatus?
  paymentDelayDays                   Int?
  amountUnpaid                       Int? // whole GBP, optional
  formalDispute                      YesNoUnsure?

  // --- Private Client survey: Level 1 raw fact capture (added ETAP 1) ---
  // Payments: stored as a child list (see Payment model). avgPaymentDelayDays
  // is the computed mean of all payment rows for this report.
  avgPaymentDelayDays Float?

  // Abandoned invoices (> 60 days unpaid) — counted SEPARATELY from delay score.
  abandonedInvoicesCount    Int?
  abandonedInvoicesTotalGbp Int?

  // Behaviour questions (raw TAK / CZASAMI / NIE — aggregated to 1–10 in Level 2)
  behaviourExtraWorkNoCost       BehaviourAnswer? // wymagał dodatkowych prac bez zgody na koszt?
  behaviourAskedCostUpfront      BehaviourAnswer? // pytał o koszt zanim zlecił? (odwrócone)
  behaviourExpectedFreeLogistics BehaviourAnswer? // oczekiwał darmowej organizacji/logistyki?
  behaviourKeptAgreements        BehaviourAnswer? // dotrzymywał ustaleń? (odwrócone)
  behaviourRespondedOnTime       BehaviourAnswer? // odpowiadał w ustalonym czasie? (odwrócone)
  behaviourProvidedAccess        BehaviourAnswer? // zapewnił dostęp do miejsca pracy? (odwrócone)
  behaviourCommunicationSmooth   BehaviourAnswer? // współpraca/komunikacja sprawnie? (odwrócone)
  behaviourWouldRecommend        BehaviourAnswer? // poleciłbyś innym wykonawcom? (odwrócone)

  // --- Main contractor specifics (chain disputes; only for MAIN_CONTRACTOR) ---
  backChargesUnagreed   BehaviourAnswer? // potrącał za nieuzgodnione usterki? (Tak/Czasami/Nie)
  backChargesAmountGbp  Int?             // kwota potrącona £
  variationsNoPaper     BehaviourAnswer? // ustne variations, odmowa papieru? (Tak/Czasami/Nie)
  retentionStatus       String?          // NOT_RETURNED / RETURNED / WITHIN_TERM
  retentionAmountGbp    Int?             // kwota retention £
  projectReadinessScore Int?             // gotowość projektu 1-10

  // --- Service providers (PM / QS / Architect-PM; no payments) ---
  spReporterRole       String? // rola, np. "Project Manager", "Senior QS" (funkcja, nie nazwisko)
  // Project manager — wszystkie 1-10
  pmScheduleScore      Int? // harmonogram przygotowany/realistyczny
  pmTenderDistribScore Int? // dokumenty przetargowe do wszystkich równo
  pmDtmProfessionalScore Int? // DTM prowadzone profesjonalnie
  pmImpartialScore     Int? // bezstronny, nie zawsze po stronie klienta
  pmCoordinationScore  Int? // LEGACY — retired from the form; kept for historical PM rows
  pmDecisionsScore     Int? // decyzje na czas
  pmFragmentationScore Int? // sensowne pakiety prac (nie szkodliwe rozdrobnienie)
  pmCommunicationScore Int? // komunikacja jasna/konkretna
  pmRealisticScore     Int? // realistyczne oczekiwania/instrukcje
  pmDtmFairnessScore   Int? // sprawiedliwy podział odpowiedzialności na DTM
  pmWouldRecommendScore Int? // would work with this PM again (1-10)

  // Quantity surveyor — wszystkie 1-10
  qsFairTenderScore          Int? // wszyscy ten sam spec (like-for-like)
  qsTenderDocsScore          Int? // dokumentacja przetargowa kompletna/jasna
  qsPriceChallengeScore      Int? // kwestionowanie ceny na podstawie sprawdzenia
  qsOpenToExplanationScore   Int? // otwarty na wyjaśnienia skąd cena
  qsMeasurementScore         Int? // obmiary dokładne
  qsVariationPricingScore    Int? // variations wyceniane sprawiedliwie
  qsClaimsScore              Int? // uznawał uzasadnione roszczenia
  qsVariationAcceptanceScore Int? // sprawiedliwa akceptacja uzasadnionej variation
  qsCertTimingScore          Int? // certyfikaty płatności na czas
  qsUnfairDeductionsScore    Int? // brak niesprawiedliwych potrąceń w certyfikatach
  qsFinalAccountScore        Int? // rozliczenie końcowe uczciwe/terminowe
  qsImpartialScore           Int? // bezstronny, nie zawsze po stronie klienta
  qsCommunicationScore       Int? // komunikacja jasna/konkretna/terminowa
  qsWouldRecommendScore      Int? // poleciłbyś ponownie

  // Łączone role — PM/architekt mógł być też QS (blok QS wypełniony)
  alsoActedAsQs Boolean?

  // Architect-PM — wszystkie 1-10
  arDrawingsAccurateScore Int? // rysunki dokładne (wymiary zgodne)
  arCompletenessScore     Int? // dokumentacja kompletna
  arCoordinationScore     Int? // rysunki branż skoordynowane
  arErrorFreeScore        Int? // wolny od błędów wymuszających przeróbki
  arTimelinessScore       Int? // info/rysunki/RFI/zmiany na czas (3-w-1)
  arFewChangesScore       Int? // rozsądnie mało zmian projektu
  arBuildabilityScore     Int? // otwarty na sugestie wykonawcy (buildability)
  arImpartialScore        Int? // bezstronny/uczciwy
  arWouldRecommendScore   Int? // poleciłbyś ponownie

  // Architekt mógł być też PM (blok PM wypełniony)
  alsoActedAsPm Boolean?

  // Evidence types the reporter claims to hold (checkboxes), e.g.
  // "INVOICES,SMS_EMAIL,PHOTOS,BANK_STATEMENT,OTHER". Files come later.
  evidenceTypes String?

  // When the reporter ticked all mandatory legal consents.
  consentsAcceptedAt DateTime?

  // --- Narrative ---
  issueDescription String // PRIVATE detail held for moderation
  publicSummary    String? // moderated, safe-for-public summary

  // --- Moderation / governance ---
  evidenceStatus   EvidenceStatus   @default(UNVERIFIED)
  moderationStatus ModerationStatus @default(PENDING)
  visibility       Visibility       @default(VERIFIED_CONTRACTORS_ONLY)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments       Payment[]
  evidence       Evidence[]
  rightToReplies RightToReply[]

  @@index([moderationStatus])
  @@index([entityType])
  @@index([publicArea])
}

// Individual payment row for a report (Private Client and other paying types).
// daysLate = 0 means paid on time or early. amountGbp is optional.
model Payment {
  id           String     @id @default(cuid())
  riskReport   RiskReport @relation(fields: [riskReportId], references: [id], onDelete: Cascade)
  riskReportId String
  position     Int // order in the list (1, 2, 3 …)
  daysLate     Int // 0 = on time / early
  amountGbp    Int? // optional, whole GBP
  createdAt    DateTime   @default(now())

  @@index([riskReportId])
}

model Evidence {
  id           String               @id @default(cuid())
  riskReport   RiskReport           @relation(fields: [riskReportId], references: [id], onDelete: Cascade)
  riskReportId String
  type         String // e.g. "DESCRIPTION", "DOCUMENT", "PHOTO", "EMAIL"
  fileUrl      String?
  description  String?
  status       EvidenceReviewStatus @default(PENDING)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([riskReportId])
}

model RightToReply {
  id            String             @id @default(cuid())
  riskReport    RiskReport         @relation(fields: [riskReportId], references: [id], onDelete: Cascade)
  riskReportId  String
  responderName String
  responderEmail String
  responseText  String
  status        RightToReplyStatus @default(PENDING)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([riskReportId])
}

model VisitStat {
  day   String @id
  count Int    @default(0)
}
